{
  "name": "promptexify",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "tsx scripts/seed-migrations.ts && drizzle-kit migrate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:deploy": "tsx scripts/deploy-db.ts",
    "db:rls": "tsx -e \"import('dotenv/config'); import('postgres').then(m => { const sql = m.default(process.env.DIRECT_URL ?? process.env.DATABASE_URL); import('fs').then(f => sql.unsafe(f.readFileSync('scripts/rls-functions.sql','utf-8')).then(() => { console.log('RLS functions applied'); sql.end(); })) })\"",
    "db:seed": "echo 'No seed script'",
    "db:studio": "drizzle-kit studio",
    "db:reset": "drizzle-kit drop",
    "db:push": "drizzle-kit push",
    "content:generate": "tsx -e \"import('./lib/automation/service.ts').then(m => m.AutomationService.executeContentGeneration()).catch(console.error)\"",
    "lint:fix": "eslint . --fix",
    "lint:format": "prettier --write .",
    "worker": "node -r dotenv/config -r ts-node/register scripts/worker.ts",
    "csp:hash": "tsx scripts/csp-manager.ts -a generate-hash",
    "csp:add": "tsx scripts/csp-manager.ts -a add-hash",
    "csp:list": "tsx scripts/csp-manager.ts -a list-hashes",
    "csp:validate": "tsx scripts/csp-manager.ts -a validate-hash",
    "csp:policy": "tsx scripts/csp-manager.ts -a create-policy",
    "csp:analyze": "tsx scripts/csp-manager.ts -a analyze-violation",
    "csp:debug": "tsx scripts/debug-csp-violation.ts",
    "csp:test": "tsx scripts/test-csp-violations.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.832.0",
    "@aws-sdk/s3-request-presigner": "^3.832.0",
    "@hookform/resolvers": "^5.1.1",
    "@next/third-parties": "^15.4.4",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.50.0",
    "@tabler/icons-react": "^3.34.0",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/analytics": "^1.5.0",
    "bullmq": "^5.56.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "csv-parser": "^3.2.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.6",
    "dotenv": "^17.0.1",
    "drizzle-orm": "^0.45.1",
    "file-type": "^19.0.0",
    "framer-motion": "^12.23.0",
    "fs.promises": "^0.1.2",
    "geist": "^1.4.2",
    "ioredis": "^5.6.1",
    "jsdom": "^26.1.0",
    "lucide-react": "^0.516.0",
    "masonic": "^4.1.0",
    "nanoid": "^5.1.5",
